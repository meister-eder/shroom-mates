# Shroom-Mates Backend — Local Development
# Copy to .env and fill in your values

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/shroom-mates

# Redis (required for production, optional for local dev — leave empty for in-memory)
# REDIS_URL=redis://localhost:6379

# Medusa secrets — generate with: openssl rand -base64 32
JWT_SECRET=dev-jwt-secret-not-for-production
COOKIE_SECRET=dev-cookie-secret-not-for-production

# CORS — local development defaults
STORE_CORS=http://localhost:8000
ADMIN_CORS=http://localhost:9000
AUTH_CORS=http://localhost:8000,http://localhost:9000

# Backend URL — used for admin redirects, file URLs, and webhook callbacks
MEDUSA_BACKEND_URL=http://localhost:9000

# SumUp Payment Provider (optional — skip if using Manual Payment only)
# Sign up for a sandbox account at https://me.sumup.com/ → Sandbox Merchant Account
# SUMUP_API_KEY=sup_sk_your_sandbox_key_here
# SUMUP_MERCHANT_CODE=MXXXXXX
# SUMUP_MEDUSA_URL=http://localhost:9000
# SUMUP_REDIRECT_URL=http://localhost:8000/de/checkout/complete
