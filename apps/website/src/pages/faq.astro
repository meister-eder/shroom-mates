---
import Layout from "../layouts/Layout.astro";
import { getEntry } from "astro:content";

const faqPageEntry = await getEntry("faq-page", "content");
if (!faqPageEntry) {
    throw new Error("FAQ page content not found");
}

const { title, description, faqs } = faqPageEntry.data;

// FAQPage structured data for Google rich snippets
const faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((faq) => ({
        "@type": "Question",
        name: faq.question,
        acceptedAnswer: {
            "@type": "Answer",
            text: faq.answer,
        },
    })),
};
---

<Layout title={title} description={description}>
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

    <main>
        <div class="hero-section">
            <h1>Häufige Fragen zu Pilzen, Growkits & Tinkturen</h1>
            <p class="subtitle">
                Alles rund um frische Pilze kaufen in Leipzig, Growkits zum
                Selberziehen, handgemachte Pilztinkturen und
                Gastronomie-Lieferungen.
            </p>
        </div>

        <div class="faq-content">
            <div class="faq-list">
                {
                    faqs.map((faq, index) => (
                        <details
                            class="faq-item reveal"
                            style={`--reveal-delay: ${index * 80}ms`}
                        >
                            <summary class="faq-question">
                                <span>{faq.question}</span>
                                <svg
                                    class="faq-chevron"
                                    width="24"
                                    height="24"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    aria-hidden="true"
                                    focusable="false"
                                >
                                    <polyline points="6 9 12 15 18 9" />
                                </svg>
                            </summary>
                            <div class="faq-answer">
                                <p set:html={faq.answer} />
                            </div>
                        </details>
                    ))
                }
            </div>

            <section class="faq-cta reveal" aria-label="Kontakt">
                <h2>Noch Fragen?</h2>
                <p>
                    Schreib uns einfach an
                    <a href="mailto:hey@shroom-mates.de">hey@shroom-mates.de</a> oder
                    besuche unsere <a href="/kontakt/">Kontaktseite</a>.
                </p>
            </section>
        </div>
    </main>
</Layout>

<style>
    main {
        min-height: 100vh;
        padding: 0;
    }

    .hero-section {
        width: calc(100vw - var(--scrollbar-width, 0px));
        margin-left: calc(50% - (100vw - var(--scrollbar-width, 0px)) / 2);
        margin-top: -1.5rem;
        padding: 4.5rem 2rem 3.5rem;
        text-align: center;
        background: var(--bg-accent);
        border-bottom: 2px solid #000;
    }

    h1 {
        font-size: clamp(2rem, 4vw, 2.8rem);
        font-weight: 700;
        line-height: 1.2;
        color: var(--text-color);
        margin: 0 0 0.5rem;
        font-family: monospace;
    }

    h1::after {
        content: "";
        display: block;
        width: 60px;
        height: 3px;
        background: var(--accent);
        margin: 0.75rem auto 0;
        border-radius: 2px;
    }

    .subtitle {
        font-size: clamp(1rem, 2vw, 1.15rem);
        color: var(--text-color);
        margin: 1.25rem auto 0;
        opacity: 0.75;
        max-width: 600px;
        line-height: 1.6;
    }

    .faq-content {
        max-width: 800px;
        margin: 0 auto;
        padding: 3rem 2rem;
    }

    .faq-list {
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .faq-item {
        border-top: 2px solid #000;
        padding: 0;
        transition: background-color 0.2s ease;
    }

    .faq-item:last-child {
        border-bottom: 2px solid #000;
    }

    .faq-item[open] {
        background: rgba(253, 252, 234, 0.5);
    }

    .faq-question {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.25rem 0.75rem;
        cursor: pointer;
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--text-color);
        list-style: none;
        gap: 1rem;
        transition: color 0.2s ease;
    }

    .faq-question:hover {
        color: var(--accent);
    }

    .faq-question::-webkit-details-marker {
        display: none;
    }

    .faq-question::marker {
        content: "";
    }

    .faq-question:focus-visible {
        outline: 2px solid var(--focus-color, #000);
        outline-offset: -2px;
    }

    .faq-chevron {
        flex-shrink: 0;
        transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
        color: var(--accent);
    }

    .faq-item[open] .faq-chevron {
        transform: rotate(180deg);
    }

    .faq-answer {
        padding: 0 0.75rem 1.5rem;
        font-size: 1rem;
        line-height: 1.7;
        color: var(--text-color);
        animation: faq-slide-in 0.3s cubic-bezier(0.22, 1, 0.36, 1);
    }

    @keyframes faq-slide-in {
        from {
            opacity: 0;
            transform: translateY(-8px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .faq-answer :global(a) {
        color: var(--accent);
        text-decoration: underline;
        text-underline-offset: 3px;
    }

    .faq-answer :global(a:hover) {
        text-decoration-thickness: 2px;
    }

    .faq-cta {
        margin-top: 4rem;
        text-align: center;
        padding: 2rem;
        background: var(--bg-color);
        border-radius: 8px;
        border: 2px solid #000;
        box-shadow: 6px 6px 0 rgba(0, 0, 0, 0.1);
    }

    .faq-cta h2 {
        font-size: 1.5rem;
        margin: 0 0 0.75rem 0;
        font-family: monospace;
    }

    .faq-cta p {
        margin: 0;
        font-size: 1.05rem;
        line-height: 1.6;
    }

    .faq-cta a {
        color: var(--accent);
        text-decoration: underline;
        text-underline-offset: 3px;
        font-weight: 600;
    }

    .faq-cta a:hover {
        text-decoration-thickness: 2px;
    }

    @media (max-width: 768px) {
        .hero-section {
            padding: 3.5rem 1.5rem 2.5rem;
            margin-top: -1rem;
        }

        .faq-content {
            padding: 2rem 1.5rem;
        }
    }

    @media (max-width: 480px) {
        .hero-section {
            padding: 2.5rem 1rem 2rem;
        }

        .faq-content {
            padding: 1.5rem 1rem;
        }

        .faq-question {
            font-size: 1rem;
            padding: 1rem 0.5rem;
        }
    }
</style>
