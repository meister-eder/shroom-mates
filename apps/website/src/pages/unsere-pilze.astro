---
import Layout from "../layouts/Layout.astro";
import ProductCard from "../components/ProductCard.astro";
import { getCollection, render } from "astro:content";

const title = "Frische Pilze kaufen in Leipzig – Edelpilze von shroom-mates";
const description =
  "Frische Edelpilze direkt vom Züchter in Leipzig-Plagwitz: Rosenseitling, Pioppino, Lion's Mane, White Pearl & mehr. Für Privat und Gastronomie, nachhaltig angebaut mit regionalen Bio-Rohstoffen.";
const noBackground = true;

// Get mushrooms from the mushrooms collection and render their content
const mushroomsCollection = await getCollection("mushrooms");
const mushrooms = await Promise.all(
  mushroomsCollection
    .sort((a, b) => a.data.order - b.data.order)
    .map(async (entry) => {
      const { Content } = await render(entry);
      return {
        title: entry.data.title,
        image: entry.data.image,
        imageAlt: entry.data.imageAlt,
        Content, // Rendered component instead of raw body
        color: entry.data.color,
        slug: entry.id,
      };
    }),
);

// Generate Product Schema for each mushroom (without offers — no online shop)
const productSchemas = mushrooms.map((mushroom) => ({
  "@context": "https://schema.org",
  "@type": "Product",
  name: mushroom.title,
  description: `Frische ${mushroom.title} aus nachhaltiger Zucht in Leipzig. Erhältlich auf dem Egenberger Samstagsmarkt.`,
  image: mushroom.image.src,
  brand: {
    "@type": "Brand",
    name: "shroom-mates",
  },
  category: "Edelpilze",
  isRelatedTo: {
    "@type": "Product",
    name: "Growkit",
    description: "Pilzzuchtset zum Selberziehen",
  },
}));
---

<Layout title={title} description={description} noBackground>
  <!-- Product Schema for each mushroom -->
  {
    productSchemas.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))
  }

  <main class="full-width-page">
    <h1 class="sr-only">
      Frische Pilze kaufen in Leipzig – Edelpilze von shroom-mates
    </h1>
    <div class="mushrooms-grid">
      {
        mushrooms.map((mushroom) => (
          <ProductCard
            title={mushroom.title}
            image={mushroom.image}
            imageAlt={mushroom.imageAlt}
            color={mushroom.color}
            id={mushroom.slug}
            imageWidth={1920}
            imageHeight={1080}
          >
            <mushroom.Content />
          </ProductCard>
        ))
      }
    </div>

    {
      mushrooms.length === 0 && (
        <div class="no-content">
          <p>
            Derzeit sind keine Pilzsorten verfügbar. Bitte schauen Sie später
            wieder vorbei.
          </p>
        </div>
      )
    }
  </main>
</Layout>

<style>
  .full-width-page {
    padding: 0 !important;
    margin: 0 !important;
    max-width: none !important;
    min-height: 100vh;
    width: 100% !important;
    background: #ffffff;
    margin-top: var(--navbar-height);
  }

  /* Remove parent padding for flush layout */
  :global(.site-main:has(.full-width-page)) {
    padding-top: 0 !important;
  }

  .mushrooms-grid {
    display: flex;
    flex-direction: column;
    gap: 0;
    width: calc(100vw - var(--scrollbar-width, 0px));
    margin-left: calc(50% - (100vw - var(--scrollbar-width, 0px)) / 2);
  }

  .no-content {
    text-align: center;
    padding: 4rem 2rem;
    color: var(--text-color);
  }

  .no-content p {
    font-size: 1.2rem;
    opacity: 0.7;
  }

  /* Mobile breakpoint */
  @media (max-width: 768px) {
    .full-width-page {
      margin-top: var(--navbar-height-mobile);
      padding-top: 0 !important;
    }

    :global(.site-main:has(.full-width-page)) {
      margin-top: 64px !important;
    }
  }
</style>
