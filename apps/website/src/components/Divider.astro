---
// Props can be passed here if needed
const { text = "🍄🍄🍄 🍄🍄🍄 🍄🍄🍄" } = Astro.props;
---

<div class="divider-container" role="presentation">
  <div class="divider-line">
    <span class="moving-text" aria-hidden="true">{text}</span>
    <span class="moving-text moving-text--delayed" aria-hidden="true"
      >{text}</span
    >
  </div>
</div>

<style>
  .divider-container {
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    margin: 0rem 0;
  }

  .divider-line {
    position: relative;
    width: 100%;
    height: 20px;
    background-color: transparent;
    overflow: hidden;
  }

  .moving-text {
    position: absolute;
    top: -3px;
    animation: move-text 6s linear infinite;
    font-size: 1rem;
    white-space: nowrap;
  }

  .moving-text--delayed {
    animation-delay: -3s;
  }

  @keyframes move-text {
    0% {
      right: -30%;
    }
    100% {
      right: 100%;
    }
  }
</style>
