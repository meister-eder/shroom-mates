---
import SvgHeading from "../../../components/SvgHeading.astro";
import { Image } from "astro:assets";
import logoWithShrooms from "../../../assets/logo_with_shrooms.png";
import { CartButton } from "./CartButton";

interface Props {
  countryCode: string;
  regionId: string | null;
}

const { countryCode, regionId } = Astro.props;
---

<header role="banner">
  <nav role="navigation" aria-label="Shop Navigation">
    <div class="nav-left">
      <a href="https://shroom-mates.de" class="nav-link back-link">
        &larr; Website
      </a>
      <a href={`/${countryCode}/store`} class="nav-link"> Produkte </a>
    </div>

    <div class="nav-center">
      <a
        href={`/${countryCode}`}
        class="logo-link"
        aria-label="Shroom-Mates Shop Startseite"
      >
        <Image
          src={logoWithShrooms}
          alt=""
          width={80}
          height={80}
          loading="eager"
          format="webp"
          class="logo-img"
        />
        <SvgHeading
          tag="div"
          src="/assets/headings/logo_font.svg"
          alt="shroom-mates"
          color="var(--accent)"
        />
      </a>
    </div>

    <div class="nav-right">
      <CartButton client:load regionId={regionId} />
    </div>
  </nav>
</header>

<script>
  function setupShrinkingNavbar() {
    const header = document.querySelector("header");
    if (!header) return;
    const scrollThreshold = 50;
    let ticking = false;

    function handleScroll() {
      if (!header) return;
      if (window.scrollY > scrollThreshold) {
        header.classList.add("scrolled");
      } else {
        header.classList.remove("scrolled");
      }
    }

    function onScroll() {
      if (!ticking) {
        requestAnimationFrame(() => {
          handleScroll();
          ticking = false;
        });
        ticking = true;
      }
    }

    window.addEventListener("scroll", onScroll, { passive: true });
    handleScroll();
  }

  setupShrinkingNavbar();
  document.addEventListener("astro:after-swap", setupShrinkingNavbar);
</script>

<style>
  header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    background: var(--bg-accent, #fdfcea);
    border-bottom: 2px solid #000;
    transition: all 0.3s ease-in-out;
  }

  nav {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 0.5rem 2rem;
    max-width: 1200px;
    margin: 0 auto;
    gap: 1rem;
    min-height: 56px;
    transition: all 0.3s ease-in-out;
  }

  header.scrolled nav {
    min-height: 44px;
    padding: 0.25rem 2rem;
  }

  .nav-left {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .nav-link {
    font-family: "DM Mono", monospace;
    font-size: 0.9rem;
    color: var(--text-color, #1d1d1d);
    text-decoration: none;
    position: relative;
    padding: 0.25rem 0;
    transition: color 0.2s ease;
  }

  .nav-link::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--accent, #ff4908);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .nav-link:hover::after,
  .nav-link:focus-visible::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  .nav-link:hover {
    color: var(--accent, #ff4908);
  }

  .nav-link:focus-visible {
    outline: 2px solid var(--accent, #ff4908);
    outline-offset: 2px;
  }

  .nav-center {
    justify-self: center;
  }

  .logo-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    transition: all 0.3s ease-in-out;
  }

  .logo-img {
    height: 50px;
    width: auto;
    transition: all 0.3s ease-in-out;
  }

  header.scrolled .logo-img {
    height: 36px;
  }

  .logo-link :global(.svg-heading) {
    font-size: 0.65rem;
    transition: all 0.3s ease-in-out;
  }

  .logo-link :global(.svg-heading svg) {
    max-width: 100%;
    height: auto;
    overflow: visible;
  }

  header.scrolled .logo-link :global(.svg-heading) {
    font-size: 0.55rem;
  }

  .nav-right {
    justify-self: end;
  }

  @media (max-width: 640px) {
    nav {
      padding: 0.4rem 1rem;
      gap: 0.5rem;
    }

    .nav-link {
      font-size: 0.8rem;
    }

    .nav-left {
      gap: 0.75rem;
    }

    .logo-img {
      height: 36px;
    }

    .logo-link :global(.svg-heading) {
      display: none;
    }
  }
</style>
