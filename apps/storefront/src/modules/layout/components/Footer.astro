---
// Thin wrapper: storefront-specific Footer links
import SharedFooter from "@shroom-mates/ui/Footer.astro";
import type { FooterLink } from "@shroom-mates/ui/Footer.astro";

interface Props {
  countryCode: string;
}

const { countryCode } = Astro.props;
---

<SharedFooter
  links={[
    { label: "Shop", href: `/${countryCode}/store` },
    { label: "Unsere Pilze", href: "https://shroom-mates.de/unsere-pilze/", external: true },
    { label: "FAQ", href: "https://shroom-mates.de/faq/", external: true },
    { label: "Kontakt", href: "https://shroom-mates.de/kontakt/", external: true },
    { label: "Datenschutz", href: `/${countryCode}/datenschutz` },
    { label: "Widerruf", href: `/${countryCode}/widerruf` },
    { label: "AGB", href: `/${countryCode}/agb` },
    { label: "Impressum", href: "https://shroom-mates.de/impressum/", external: true },
    { label: "hey@shroom-mates.de", href: "mailto:hey@shroom-mates.de", isEmail: true },
  ] satisfies FooterLink[]}
/>
