---
import { getProductPrice } from "../../../../lib/utils/get-product-price";
import type { ProductVariant } from "../../../../types/global";
import Thumbnail from "../thumbnail/Thumbnail.astro";
import Price from "./Price.astro";

interface Props {
  id: string;
  variants: ProductVariant[];
  thumbnailUrl?: string;
  imageUrl?: string;
  title: string;
  priority?: boolean;
  categoryName?: string;
}

const { id, variants, thumbnailUrl, imageUrl, title, priority, categoryName } =
  Astro.props;
const countryCode = Astro.params.countryCode;

const { cheapestPrice } = getProductPrice({ productVariants: variants });
---

<a
  href={`/${countryCode}/store/${id}`}
  class="product-card"
  aria-label={`${title}${cheapestPrice ? " — ab " + cheapestPrice.calculated_price : ""}`}
>
  <Thumbnail
    imageUrl={thumbnailUrl || imageUrl}
    title={title}
    priority={priority}
  />

  <div class="product-card-body">
    {
      categoryName && (
        <span
          class="badge badge-category"
          aria-label={`Kategorie: ${categoryName}`}
        >
          {categoryName}
        </span>
      )
    }
    <p class="product-card-title">{title}</p>
    {
      cheapestPrice && (
        <div class="mt-auto pt-1">
          <Price
            priceType={cheapestPrice.price_type ?? ""}
            originalPrice={cheapestPrice.original_price}
            calculatedPrice={cheapestPrice.calculated_price}
          />
        </div>
      )
    }
  </div>
</a>
