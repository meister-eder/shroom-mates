---
import { getRegion } from "@lib/data/regions";
import { listProducts } from "@lib/data/products";
import { Image } from "astro:assets";
import Layout from "../../layouts/Layout.astro";
import { getRegionParams } from "../../lib/params/region-params";

export const getStaticPaths = getRegionParams;

const { countryCode } = Astro.params;

const region = await getRegion(countryCode);

const products = region ? await listProducts(region.id).catch(() => []) : [];

const firstProduct = products?.[0];
const heroImage = firstProduct?.thumbnail ?? firstProduct?.images?.[0]?.url;
---

<Layout
  description="Frische Pilze, Growkits und Tinkturen aus Leipzig — direkt vom Erzeuger bestellen."
  image={heroImage}
>
  <section
    class="flex items-center min-h-[calc(100vh-10rem)] gap-12 px-8 py-16 rounded-2xl overflow-hidden"
    style="background: var(--bg-accent, #fdfcea);"
  >
    <div class="flex flex-col gap-6 w-full md:flex-1 md:max-w-2xl">
      <h1 class="text-5xl font-bold leading-tight tracking-tight">
        Frische Pilze &amp; Pilzprodukte aus Leipzig
      </h1>
      <p class="text-gray-600 text-lg leading-relaxed">
        Growkits, Tinkturen und frische Edelpilze — nachhaltig angebaut und
        direkt zu dir nach Hause.
      </p>
      <div class="flex items-center gap-4 mt-2">
        <a href={`/${countryCode}/store`} class="btn-accent"> Zum Shop </a>
        <a
          href="https://shroom-mates.de"
          class="px-6 py-3 text-sm font-medium rounded-md transition-colors"
          style="border: 2px solid #000; font-family: 'DM Mono', monospace;"
        >
          Über uns
        </a>
      </div>
    </div>

    <div
      class="hidden md:flex flex-1 relative items-center justify-center h-full"
    >
      {
        heroImage ? (
          <Image
            src={heroImage}
            width={800}
            height={900}
            alt={firstProduct?.title ?? "Produktbild"}
            widths={[400, 600, 800]}
            sizes="(max-width: 1024px) 50vw, 40vw"
            format="webp"
            quality={85}
            class="relative z-10 w-full h-full object-contain"
          />
        ) : (
          <div
            class="relative z-10 w-full max-w-lg h-[500px] rounded-xl"
            style="background: var(--accent, #ff4908); border: 3px solid #000;"
          />
        )
      }
    </div>
  </section>
</Layout>
