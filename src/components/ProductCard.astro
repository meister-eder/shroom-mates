---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { readableTextColor } from "../utils/color";

interface Props {
	title: string;
	image: ImageMetadata;
	imageAlt: string;
	color?: string;
	headingLevel?: 2 | 3;
	subtitle?: string;
	id?: string;
	imageWidth?: number;
	imageHeight?: number;
}

const {
	title,
	image,
	imageAlt,
	color,
	headingLevel = 2,
	subtitle,
	id,
	imageWidth = 800,
	imageHeight = 600,
} = Astro.props;

const HeadingTag = `h${headingLevel}` as "h2" | "h3";
const contentStyle = color
	? `background-color: ${color}; color: ${readableTextColor(color)};`
	: "";
---

<article class="product-card" id={id}>
	<div class="product-content" style={contentStyle}>
		<HeadingTag>{title}</HeadingTag>
		{subtitle && <p class="product-subtitle"><em>{subtitle}</em></p>}
		<div class="product-description">
			<slot />
		</div>
	</div>
	<div class="product-image-wrapper">
		<Image
			src={image}
			alt={imageAlt}
			width={imageWidth}
			height={imageHeight}
			format="webp"
			loading="lazy"
			class="product-image"
		/>
	</div>
</article>

<style>
	.product-card {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 0;
		align-items: stretch;
		min-height: 50vh;
		width: 100%;
		border-top: 2px solid #000;
		background: #ffffff;
	}

	.product-card:last-child {
		border-bottom: 2px solid #000;
	}

	.product-card:nth-child(even) .product-content {
		order: 2;
	}

	.product-card:nth-child(even) .product-image-wrapper {
		order: 1;
	}

	.product-image-wrapper {
		width: 100%;
		height: 100%;
		min-height: 50vh;
		overflow: hidden;
		position: relative;
	}

	.product-image {
		width: 100%;
		height: 100%;
		display: block;
		object-fit: cover;
		min-height: 50vh;
	}

	.product-content {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		padding: 3rem 4rem;
		background: #ffffff;
		height: 100%;
		justify-content: center;
	}

	.product-content h2,
	.product-content h3 {
		font-size: 2rem;
		font-weight: 700;
		line-height: 1.2;
		margin: 0 0 0.5rem 0;
		color: inherit;
	}

	.product-subtitle {
		font-size: 1.05rem;
		margin: 0 0 1rem 0;
		opacity: 0.8;
		color: inherit;
	}

	.product-description {
		font-size: 1rem;
		line-height: 1.7;
		color: inherit;
	}

	.product-description :global(h2) {
		font-size: 1.3rem;
		font-weight: 600;
		margin: 1.5rem 0 0.75rem 0;
	}

	.product-description :global(h2:first-child) {
		margin-top: 0;
	}

	.product-description :global(h3) {
		font-size: 1.1rem;
		font-weight: 600;
		margin: 1.25rem 0 0.5rem 0;
	}

	.product-description :global(p) {
		margin: 0 0 0.75rem 0;
	}

	.product-description :global(p:last-child) {
		margin-bottom: 0;
	}

	.product-description :global(ul),
	.product-description :global(ol) {
		margin: 0.75rem 0;
		padding-left: 1.25rem;
	}

	.product-description :global(li) {
		margin: 0.35rem 0;
	}

	.product-description :global(strong) {
		font-weight: 700;
	}

	.product-description :global(em) {
		font-style: italic;
	}

	.product-description :global(a) {
		color: inherit;
		text-decoration: underline;
		text-underline-offset: 2px;
	}

	.product-description :global(a:hover) {
		text-decoration-thickness: 2px;
	}

	/* Tablet breakpoint */
	@media (max-width: 968px) {
		.product-content {
			padding: 2rem 2.5rem;
		}

		.product-content h2,
		.product-content h3 {
			font-size: 1.7rem;
		}
	}

	/* Mobile breakpoint */
	@media (max-width: 768px) {
		.product-card {
			grid-template-columns: 1fr;
			min-height: auto;
			display: flex;
			flex-direction: column;
		}

		.product-content {
			order: 1 !important;
			padding: 2rem 1.5rem;
		}

		.product-image-wrapper {
			order: 2 !important;
			min-height: 40vh;
		}

		.product-image {
			min-height: 40vh;
		}

		.product-content h2,
		.product-content h3 {
			font-size: 1.5rem;
		}

		.product-description {
			font-size: 0.95rem;
		}
	}

	/* Small mobile breakpoint */
	@media (max-width: 480px) {
		.product-image-wrapper {
			min-height: 35vh;
		}

		.product-image {
			min-height: 35vh;
		}

		.product-content {
			padding: 1.5rem 1rem;
		}

		.product-content h2,
		.product-content h3 {
			font-size: 1.3rem;
		}

		.product-description {
			font-size: 0.9rem;
		}
	}
</style>
