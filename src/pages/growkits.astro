---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import ProductCard from "../components/ProductCard.astro";
import { getCollection, getEntry, render } from "astro:content";

// Get the growkits page content (generic instructions)
const growkitsPageEntry = await getEntry("growkits-page", "content");
if (!growkitsPageEntry) {
  throw new Error("Growkits page content not found");
}
const { Content: PageContent } = await render(growkitsPageEntry);

const {
  title,
  description,
  heroTitle,
  heroSubtitle,
  heroImage,
  heroImageAlt,
  ctaTitle,
  ctaText,
  ctaButtonText,
  ctaButtonLink,
} = growkitsPageEntry.data;

// Get growkit varieties from the collection
const growkitsCollection = await getCollection("growkits");
const growkits = await Promise.all(
  growkitsCollection
    .sort((a, b) => a.data.order - b.data.order)
    .map(async (entry) => {
      const { Content } = await render(entry);
      return {
        title: entry.data.title,
        image: entry.data.image,
        imageAlt: entry.data.imageAlt,
        Content,
        color: entry.data.color,
        slug: entry.id,
      };
    }),
);

// Generate HowTo Schema for SEO
const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: "Pilze zuhause züchten mit Growkits",
  description:
    "Schritt-für-Schritt Anleitung zum Züchten von Pilzen mit unseren Growkits. Lion's Mane, Rosenseitlinge und White Pearl in wenigen Wochen ernten.",
  image: heroImage?.src || "",
  totalTime: "P21D",
  estimatedCost: {
    "@type": "MonetaryAmount",
    currency: "EUR",
    value: "25",
  },
  supply: [
    {
      "@type": "HowToSupply",
      name: "Growkit",
    },
    {
      "@type": "HowToSupply",
      name: "Sprühflasche mit Wasser",
    },
  ],
  tool: [
    {
      "@type": "HowToTool",
      name: "Heller Standort ohne direkte Sonneneinstrahlung",
    },
  ],
  step: [
    {
      "@type": "HowToStep",
      name: "Auspacken & Vorbereiten",
      text: "Nimm das Growkit aus der Verpackung und stelle es an einen hellen Ort ohne direkte Sonneneinstrahlung.",
      position: 1,
    },
    {
      "@type": "HowToStep",
      name: "Befeuchten",
      text: "Besprühe das Kit 2-3 mal täglich mit Wasser. Die Oberfläche sollte immer leicht feucht sein.",
      position: 2,
    },
    {
      "@type": "HowToStep",
      name: "Warten & Beobachten",
      text: "Nach etwa 7-14 Tagen zeigen sich die ersten Pilzköpfe. Ab dann geht es schnell!",
      position: 3,
    },
    {
      "@type": "HowToStep",
      name: "Ernten",
      text: "Ernte die Pilze, wenn die Hutkanten beginnen sich nach oben zu wölben. Drehe sie vorsichtig ab.",
      position: 4,
    },
  ],
};

// Generate Product schema for each growkit variety
const productSchemas = growkits.map((growkit) => ({
  "@context": "https://schema.org",
  "@type": "Product",
  name: `${growkit.title} Growkit`,
  description: `Pilzzuchtset für ${growkit.title} - Frische Pilze zuhause züchten`,
  image: growkit.image?.src || "",
  brand: {
    "@type": "Brand",
    name: "shroom-mates",
  },
  manufacturer: {
    "@type": "Organization",
    name: "shroom-mates",
    url: "https://shroom-mates.de",
  },
  category: "Pilzzucht",
}));
---

<Layout title={title} description={description} ogImage={heroImage?.src}>
  <!-- HowTo Schema for SEO -->
  <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />

  <!-- Product Schemas for each growkit variety -->
  {
    productSchemas.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))
  }

  <!-- Hero Section with Image + Text Overlay -->
  {
    heroImage && (
      <section class="hero">
        <Image
          src={heroImage}
          alt={heroImageAlt || "Growkits Anleitung"}
          class="hero-image"
          width={1920}
          height={1080}
          priority
          format="webp"
          decoding="async"
        />
        <div class="hero-overlay">
          <h1 class="hero-title">{heroTitle}</h1>
          {heroSubtitle && <p class="hero-subtitle">{heroSubtitle}</p>}
        </div>
      </section>
    )
  }

  <!-- Main Content Section -->
  <section class="growkits-section reveal" id="content">
    <!-- Generic Instructions from CMS -->
    <div class="instructions-content">
      <PageContent />
    </div>
  </section>

  <!-- Growkit Varieties Section -->
  {
    growkits.length > 0 && (
      <section class="varieties-section" aria-label="Growkit Sorten">
        <h2 class="section-heading">Unsere Growkit Sorten</h2>

        <div class="varieties-grid">
          {growkits.map((growkit) => (
            <ProductCard
              title={growkit.title}
              image={growkit.image}
              imageAlt={growkit.imageAlt}
              color={growkit.color}
              headingLevel={3}
              id={growkit.slug}
            >
              <growkit.Content />
            </ProductCard>
          ))}
        </div>
      </section>
    )
  }

  <!-- CTA Section -->
  {
    ctaTitle && (
      <section class="cta-section reveal" aria-label="Kontakt">
        <h2>{ctaTitle}</h2>
        {ctaText && <p>{ctaText}</p>}
        {ctaButtonText && ctaButtonLink && (
          <a href={ctaButtonLink} class="cta-button">
            {ctaButtonText}
          </a>
        )}
      </section>
    )
  }
</Layout>

<style>
  /* Hero Section */
  .hero {
    position: relative;
    width: calc(100vw - var(--scrollbar-width, 0px));
    height: 70vh;
    margin-left: calc(50% - (100vw - var(--scrollbar-width, 0px)) / 2);
    margin-top: -1.5rem;
    overflow: hidden;
  }

  .hero::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.55) 0%,
      rgba(0, 0, 0, 0.15) 40%,
      transparent 70%
    );
    pointer-events: none;
    z-index: 1;
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-bottom: 2px solid #000;
  }

  .hero-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 2;
    padding: 3rem 2rem;
    text-align: center;
  }

  .hero-title {
    font-size: clamp(1.8rem, 4vw, 3rem);
    font-weight: 700;
    line-height: 1.15;
    margin: 0 0 0.6rem 0;
    color: #fff;
    font-family: monospace;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.4);
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-subtitle {
    font-size: clamp(0.95rem, 1.5vw, 1.15rem);
    color: rgba(255, 255, 255, 0.9);
    margin: 0;
    max-width: 550px;
    margin-left: auto;
    margin-right: auto;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.35);
    line-height: 1.5;
  }

  /* Main Content Section */
  .growkits-section {
    max-width: 800px;
    margin: 0 auto;
    padding: 3rem 2rem;
  }

  /* Prose styles for markdown content */
  .instructions-content {
    background: var(--bg-color);
    border: 2px solid var(--focus-color, #000);
    border-radius: 8px;
    padding: 2.5rem;
    box-shadow: 6px 6px 0 rgba(0, 0, 0, 0.1);
    position: relative;
  }

  .instructions-content :global(h2) {
    font-size: 1.6rem;
    font-weight: 700;
    margin: 2.5rem 0 1rem 0;
    color: var(--text-color);
    font-family: monospace;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid rgba(0, 0, 0, 0.08);
  }

  .instructions-content :global(h2:first-child) {
    margin-top: 0;
  }

  .instructions-content :global(h3) {
    font-size: 1.15rem;
    font-weight: 700;
    margin: 1.75rem 0 0.6rem 0;
    color: var(--accent);
    font-family: monospace;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .instructions-content :global(p) {
    font-size: 1rem;
    line-height: 1.75;
    margin: 0 0 1rem 0;
    color: var(--text-color);
  }

  .instructions-content :global(strong) {
    font-weight: 700;
  }

  .instructions-content :global(em) {
    font-style: italic;
  }

  .instructions-content :global(ul),
  .instructions-content :global(ol) {
    margin: 1rem 0;
    padding-left: 1.5rem;
  }

  .instructions-content :global(li) {
    font-size: 1rem;
    line-height: 1.7;
    margin: 0.5rem 0;
  }

  .instructions-content :global(hr) {
    border: none;
    border-top: 2px solid #eee;
    margin: 2rem 0;
  }

  .instructions-content :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .instructions-content :global(a:hover) {
    text-decoration-thickness: 2px;
  }

  /* Varieties Section */
  .varieties-section {
    padding: 3rem 0;
  }

  .section-heading {
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    font-weight: 700;
    text-align: center;
    margin: 0 0 0.5rem 0;
    color: var(--text-color);
    font-family: monospace;
  }

  .section-heading::after {
    content: "";
    display: block;
    width: 60px;
    height: 3px;
    background: var(--accent);
    margin: 0.75rem auto 2rem;
    border-radius: 2px;
  }

  .varieties-grid {
    display: flex;
    flex-direction: column;
    gap: 0;
    width: calc(100vw - var(--scrollbar-width, 0px));
    margin-left: calc(50% - (100vw - var(--scrollbar-width, 0px)) / 2);
  }

  /* CTA Section */
  .cta-section {
    text-align: center;
    padding: 4rem 2rem;
    max-width: 800px;
    margin: 0 auto;
    position: relative;
  }

  .cta-section::before {
    content: "";
    display: block;
    width: 40px;
    height: 3px;
    background: var(--accent);
    margin: 0 auto 2rem;
    border-radius: 2px;
  }

  .cta-section h2 {
    font-size: 1.8rem;
    font-weight: 700;
    margin: 0 0 1rem 0;
    color: var(--text-color);
    font-family: monospace;
  }

  .cta-section p {
    font-size: 1.1rem;
    color: var(--text-color);
    margin: 0 0 2rem 0;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.6;
  }

  .cta-button {
    display: inline-block;
    padding: 0.8rem 2rem;
    background: #000;
    color: #fff;
    text-decoration: none;
    border-radius: 6px;
    font-weight: 500;
    font-size: 1rem;
    font-family: "DM Mono", monospace;
    box-shadow: 4px 4px 0 rgba(0, 0, 0, 0.2);
    transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .cta-button:hover {
    transform: translate(2px, 2px);
    box-shadow: 2px 2px 0 rgba(0, 0, 0, 0.2);
    background: var(--accent);
  }

  .cta-button:active {
    transform: translate(4px, 4px);
    box-shadow: 0 0 0 rgba(0, 0, 0, 0.2);
  }

  .cta-button:focus-visible {
    outline: 2px solid var(--focus-color, #000);
    outline-offset: 2px;
  }

  /* Tablet breakpoint */
  @media (max-width: 968px) {
    .hero {
      height: 50vh;
    }

    .instructions-content {
      padding: 1.5rem;
    }

    .section-heading {
      font-size: 1.7rem;
    }
  }

  /* Mobile breakpoint */
  @media (max-width: 768px) {
    .hero {
      height: 40vh;
      margin-top: -1rem;
    }

    .hero-overlay {
      padding: 2rem 1.5rem;
    }

    .growkits-section {
      padding: 2rem 1.5rem;
    }

    .instructions-content {
      padding: 1.25rem;
    }

    .instructions-content :global(h2) {
      font-size: 1.4rem;
    }

    .instructions-content :global(h3) {
      font-size: 1.05rem;
    }

    .varieties-section {
      padding: 2rem 0;
    }

    .section-heading {
      font-size: 1.5rem;
      padding: 0 1.5rem;
    }

    .cta-section {
      padding: 2rem 1.5rem;
    }

    .cta-section h2 {
      font-size: 1.5rem;
    }

    .cta-section p {
      font-size: 1rem;
    }
  }

  /* Small mobile breakpoint */
  @media (max-width: 480px) {
    .hero {
      height: 35vh;
    }
  }
</style>
