---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import ProductCard from "../components/ProductCard.astro";
import { getCollection, getEntry, render } from "astro:content";

// Get the tinkturen page content
const tinkturenPageEntry = await getEntry("tinkturen-page", "content");
if (!tinkturenPageEntry) {
	throw new Error("Tinkturen page content not found");
}

const {
	title,
	description,
	heroTitle,
	heroSubtitle,
	heroImage,
	heroImageAlt,
	introText,
	disclaimerText,
	quellen,
} = tinkturenPageEntry.data;

// Get tincture products from the collection
const tinkturenCollection = await getCollection("tinkturen");
const tinkturen = await Promise.all(
	tinkturenCollection
		.sort((a, b) => a.data.order - b.data.order)
		.map(async (entry) => {
			const { Content } = await render(entry);
			return {
				title: entry.data.title,
				botanicalName: entry.data.botanicalName,
				image: entry.data.image,
				imageAlt: entry.data.imageAlt,
				Content,
				color: entry.data.color,
				slug: entry.id,
			};
		}),
);

// Generate Product schema for each tincture
const productSchemas = tinkturen.map((tinktur) => ({
	"@context": "https://schema.org",
	"@type": "Product",
	name: tinktur.title,
	description: `Handgemachte Pilztinktur – ${tinktur.title} (${tinktur.botanicalName}). Doppelextrakt aus eigener Zucht in Leipzig.`,
	image: tinktur.image?.src || "",
	brand: {
		"@type": "Brand",
		name: "shroom-mates",
	},
	manufacturer: {
		"@type": "Organization",
		name: "shroom-mates",
		url: "https://shroom-mates.de",
	},
	category: "Nahrungsergänzungsmittel",
	offers: {
		"@type": "Offer",
		availability: "https://schema.org/InStock",
		priceCurrency: "EUR",
		seller: {
			"@type": "LocalBusiness",
			name: "shroom-mates",
			address: {
				"@type": "PostalAddress",
				addressLocality: "Leipzig",
				addressRegion: "Sachsen",
				addressCountry: "DE",
			},
		},
	},
}));
---

<Layout title={title} description={description} ogImage={heroImage?.src}>
	<!-- Product Schemas for SEO -->
	{
		productSchemas.map((schema) => (
			<script type="application/ld+json" set:html={JSON.stringify(schema)} />
		))
	}

	<!-- Page Header -->
	<section class="page-header" id="content">
		<h1>{heroTitle}</h1>
		{heroSubtitle && <p class="subtitle">{heroSubtitle}</p>}
	</section>

	<!-- Intro Section -->
	<section class="intro-section" aria-label="Über unsere Tinkturen">
		<div class="intro-grid">
			<div class="intro-text">
				<p>{introText}</p>
			</div>
			<div class="intro-facts">
				<div class="fact-item">
					<span class="fact-label">Herstellung</span>
					<span class="fact-value">Doppelextrakt — Alkohol + Heißwasser</span>
				</div>
				<div class="fact-item">
					<span class="fact-label">Herkunft</span>
					<span class="fact-value">Eigene Indoor-Farm, Leipzig Plagwitz</span>
				</div>
				<div class="fact-item">
					<span class="fact-label">Substrat</span>
					<span class="fact-value">Regionales Bio-Substrat, ohne Zusätze</span>
				</div>
				<div class="fact-item">
					<span class="fact-label">Dosierung</span>
					<span class="fact-value">1–2 Pipetten täglich · 50 ml ≈ 25–50 Tagesdosen</span>
				</div>
			</div>
		</div>
	</section>

	<!-- Tincture Products -->
	{
		tinkturen.length > 0 && (
			<section class="products-section" aria-label="Unsere Tinkturen">
				<div class="products-grid">
					{tinkturen.map((tinktur) => (
						<ProductCard
							title={tinktur.title}
							image={tinktur.image}
							imageAlt={tinktur.imageAlt}
							color={tinktur.color}
							subtitle={tinktur.botanicalName}
							id={tinktur.slug}
						>
							<tinktur.Content />
						</ProductCard>
					))}
				</div>
			</section>
		)
	}

	<!-- Quellen Section -->
	{
		quellen && quellen.length > 0 && (
			<section class="quellen-section" aria-label="Wissenschaftliche Quellen">
				<div class="quellen-container">
					<h2>Quellen</h2>
					<ol class="quellen-list">
						{quellen.map((quelle) => (
							<li>
								<a
									href={quelle.url}
									target="_blank"
									rel="noopener noreferrer"
								>
									{quelle.title}
								</a>
							</li>
						))}
					</ol>
				</div>
			</section>
		)
	}

	<!-- Disclaimer -->
	{
		disclaimerText && (
			<section class="disclaimer-section" aria-label="Hinweis">
				<p class="disclaimer">{disclaimerText}</p>
			</section>
		)
	}
</Layout>

<style>
	/* Page Header */
	.page-header {
		max-width: 800px;
		margin: 0 auto;
		padding: 3rem 2rem 1.5rem;
		text-align: center;
	}

	.page-header h1 {
		font-size: 2.5rem;
		font-weight: 700;
		line-height: 1.2;
		margin: 0 0 0.75rem 0;
		color: var(--text-color);
		font-family: monospace;
	}

	.subtitle {
		max-width: 600px;
		margin: 0 auto;
		font-size: 1.1rem;
		line-height: 1.6;
		color: var(--text-color);
	}

	/* Intro Section */
	.intro-section {
		max-width: 1000px;
		margin: 0 auto;
		padding: 1.5rem 2rem 3rem;
	}

	.intro-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.5rem;
		align-items: start;
	}

	.intro-text {
		background: var(--bg-color);
		border: 2px solid #000;
		border-radius: 8px;
		padding: 1.75rem;
		box-shadow: 4px 4px 0 rgba(0, 0, 0, 0.15);
	}

	.intro-text p {
		font-size: 1rem;
		line-height: 1.75;
		margin: 0;
		color: var(--text-color);
	}

	.intro-facts {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.fact-item {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
		background: var(--bg-color);
		border: 2px solid #000;
		border-radius: 8px;
		padding: 1rem 1.25rem;
		box-shadow: 3px 3px 0 rgba(0, 0, 0, 0.12);
	}

	.fact-label {
		font-family: "DM Mono", monospace;
		font-size: 0.75rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--accent);
	}

	.fact-value {
		font-size: 0.95rem;
		line-height: 1.4;
		color: var(--text-color);
	}

	/* Products Section */
	.products-section {
		padding: 3rem 0;
	}

	.products-grid {
		display: flex;
		flex-direction: column;
		gap: 0;
		width: calc(100vw - var(--scrollbar-width, 0px));
		margin-left: calc(50% - (100vw - var(--scrollbar-width, 0px)) / 2);
	}

	/* Quellen Section */
	.quellen-section {
		max-width: 800px;
		margin: 0 auto;
		padding: 3rem 2rem 2rem;
	}

	.quellen-container {
		background: var(--bg-color);
		border: 2px solid var(--focus-color, #000);
		border-radius: 8px;
		padding: 2rem;
		box-shadow: 6px 6px 0 rgba(0, 0, 0, 0.1);
	}

	.quellen-container h2 {
		font-size: 1.6rem;
		font-weight: 700;
		margin: 0 0 1rem 0;
		color: var(--text-color);
		font-family: monospace;
	}

	.quellen-list {
		margin: 0;
		padding-left: 1.5rem;
		list-style-type: decimal;
	}

	.quellen-list li {
		font-size: 0.95rem;
		line-height: 1.6;
		margin: 0.5rem 0;
		color: var(--text-color);
	}

	.quellen-list a {
		color: var(--accent);
		text-decoration: underline;
		text-underline-offset: 2px;
		word-break: break-word;
	}

	.quellen-list a:hover {
		text-decoration-thickness: 2px;
	}

	.quellen-list a:focus-visible {
		outline: 2px solid var(--focus-color, #000);
		outline-offset: 2px;
	}

	/* Disclaimer Section */
	.disclaimer-section {
		max-width: 800px;
		margin: 0 auto;
		padding: 0 2rem 3rem;
	}

	.disclaimer {
		font-size: 0.85rem;
		line-height: 1.5;
		color: var(--focus-color);
		text-align: center;
		font-style: italic;
		border-top: 1px solid #ddd;
		padding-top: 1.5rem;
	}

	/* Tablet breakpoint */
	@media (max-width: 968px) {
		.page-header h1 {
			font-size: 2rem;
		}

		.intro-grid {
			grid-template-columns: 1fr;
		}
	}

	/* Mobile breakpoint */
	@media (max-width: 768px) {
		.page-header {
			padding: 2rem 1.5rem 1rem;
		}

		.page-header h1 {
			font-size: 1.8rem;
		}

		.subtitle {
			font-size: 1rem;
		}

		.intro-section {
			padding: 1rem 1.5rem 2rem;
		}

		.intro-text {
			padding: 1.25rem;
		}

		.products-section {
			padding: 2rem 0;
		}

		.quellen-section {
			padding: 2rem 1.5rem 1.5rem;
		}

		.quellen-container {
			padding: 1.25rem;
		}

		.quellen-container h2 {
			font-size: 1.4rem;
		}

		.disclaimer-section {
			padding: 0 1.5rem 2rem;
		}
	}

	/* Small mobile breakpoint */
	@media (max-width: 480px) {
		.page-header h1 {
			font-size: 1.5rem;
		}
	}
</style>
