---
import Layout from "../layouts/Layout.astro";
import { getEntry } from "astro:content";

const faqPageEntry = await getEntry("faq-page", "content");
if (!faqPageEntry) {
    throw new Error("FAQ page content not found");
}

const { title, description, faqs } = faqPageEntry.data;

// FAQPage structured data for Google rich snippets
const faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((faq) => ({
        "@type": "Question",
        name: faq.question,
        acceptedAnswer: {
            "@type": "Answer",
            text: faq.answer,
        },
    })),
};
---

<Layout title={title} description={description}>
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

    <main>
        <div class="hero-section">
            <h1>Häufige Fragen zu Pilzen, Growkits & Tinkturen</h1>
            <p class="subtitle">
                Alles rund um frische Pilze kaufen in Leipzig, Growkits zum
                Selberziehen, handgemachte Pilztinkturen und
                Gastronomie-Lieferungen.
            </p>
        </div>

        <div class="faq-content">
            <div class="faq-list">
                {
                    faqs.map((faq) => (
                        <details class="faq-item">
                            <summary class="faq-question">
                                <span>{faq.question}</span>
                                <svg
                                    class="faq-chevron"
                                    width="24"
                                    height="24"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    aria-hidden="true"
                                    focusable="false"
                                >
                                    <polyline points="6 9 12 15 18 9" />
                                </svg>
                            </summary>
                            <div class="faq-answer">
                                <p set:html={faq.answer} />
                            </div>
                        </details>
                    ))
                }
            </div>

            <section class="faq-cta" aria-label="Kontakt">
                <h2>Noch Fragen?</h2>
                <p>
                    Schreib uns einfach an
                    <a href="mailto:hey@shroom-mates.de">hey@shroom-mates.de</a> oder
                    besuche unsere <a href="/kontakt">Kontaktseite</a>.
                </p>
            </section>
        </div>
    </main>
</Layout>

<style>
    main {
        min-height: 100vh;
        padding: 0;
    }

    .hero-section {
        padding: 4rem 2rem 3rem;
        text-align: center;
        background: var(--bg-color);
        border-bottom: 2px solid var(--text-color);
    }

    h1 {
        font-size: clamp(2rem, 4vw, 2.5rem);
        font-weight: 700;
        line-height: 1.2;
        color: var(--text-color);
        margin: 0 0 1rem;
        font-family: monospace;
    }

    .subtitle {
        font-size: clamp(1rem, 2vw, 1.2rem);
        color: var(--text-color);
        margin: 0 auto;
        opacity: 0.8;
        max-width: 600px;
        line-height: 1.6;
    }

    .faq-content {
        max-width: 800px;
        margin: 0 auto;
        padding: 3rem 2rem;
    }

    .faq-list {
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .faq-item {
        border-top: 2px solid var(--text-color);
        padding: 0;
    }

    .faq-item:last-child {
        border-bottom: 2px solid var(--text-color);
    }

    .faq-question {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.25rem 0.5rem;
        cursor: pointer;
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--text-color);
        list-style: none;
        gap: 1rem;
    }

    .faq-question::-webkit-details-marker {
        display: none;
    }

    .faq-question::marker {
        content: "";
    }

    .faq-chevron {
        flex-shrink: 0;
        transition: transform 0.2s ease;
    }

    .faq-item[open] .faq-chevron {
        transform: rotate(180deg);
    }

    .faq-answer {
        padding: 0 0.5rem 1.5rem;
        font-size: 1rem;
        line-height: 1.7;
        color: var(--text-color);
    }

    .faq-answer :global(a) {
        color: var(--accent);
        text-decoration: underline;
        text-underline-offset: 3px;
    }

    .faq-answer :global(a:hover) {
        opacity: 0.8;
    }

    .faq-cta {
        margin-top: 4rem;
        text-align: center;
        padding: 2rem;
        background: var(--bg-accent);
        border-radius: 12px;
        border: 2px solid var(--text-color);
    }

    .faq-cta h2 {
        font-size: 1.5rem;
        margin: 0 0 0.75rem 0;
        font-family: monospace;
    }

    .faq-cta p {
        margin: 0;
        font-size: 1.05rem;
        line-height: 1.6;
    }

    .faq-cta a {
        color: var(--accent);
        text-decoration: underline;
        text-underline-offset: 3px;
    }

    @media (max-width: 768px) {
        .hero-section {
            padding: 3rem 1.5rem 2rem;
        }

        .faq-content {
            padding: 2rem 1.5rem;
        }
    }

    @media (max-width: 480px) {
        .hero-section {
            padding: 2.5rem 1rem 1.5rem;
        }

        .faq-content {
            padding: 1.5rem 1rem;
        }
    }
</style>
