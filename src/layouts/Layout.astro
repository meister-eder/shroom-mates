---
import "@fontsource/geist-sans";
import { ClientRouter } from "astro:transitions";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  isLandingPage?: boolean;
  noindex?: boolean;
  noBackground?: boolean;
}

const {
  title,
  description = "Frische Edelpilze, Growkits & Pilztinkturen aus Leipzig-Plagwitz. Austernpilze, Lion's Mane, Pioppino. Nachhaltig gezüchtet für Privat und Gastronomie, direkt vom Züchter.",
  ogImage,
  isLandingPage = false,
  noindex = false,
  noBackground = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
// Use a better default image - the logo with mushrooms
const defaultOgImage =
  ogImage ||
  new URL("/assets/logo_with_shrooms_and_text.png", Astro.site).toString();

// Structured data for local business SEO
const structuredData = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": "https://shroom-mates.de/#business",
  name: "shroom-mates",
  alternateName: "shroom-mates GbR",
  legalName: "shroom-mates GbR – Emmelie Kunz & Tim Eder",
  image: new URL(
    "/assets/logo_with_shrooms_and_text.png",
    Astro.site,
  ).toString(),
  description:
    "Edelpilzzucht in Leipzig-Plagwitz. Frische Austernpilze, Lion's Mane, Pioppino, Growkits und Pilztinkturen. Für Privat und Gastronomie.",
  address: {
    "@type": "PostalAddress",
    streetAddress: "Markranstädter Straße 8",
    addressLocality: "Leipzig",
    addressRegion: "Sachsen",
    postalCode: "04229",
    addressCountry: "DE",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: 51.325545,
    longitude: 12.330446,
  },
  url: "https://shroom-mates.de",
  email: "hey@shroom-mates.de",
  priceRange: "$$",
  knowsLanguage: "de",
  knowsAbout: [
    "Edelpilze",
    "Pilzzucht",
    "Austernpilze",
    "Lion's Mane",
    "Growkits",
    "Pilztinkturen",
    "Vitalpilze",
    "Pilze für Gastronomie",
  ],
  areaServed: [
    {
      "@type": "City",
      name: "Leipzig",
      "@id": "https://www.wikidata.org/wiki/Q2079",
    },
    {
      "@type": "State",
      name: "Sachsen",
    },
  ],
  sameAs: ["https://www.instagram.com/shroom_mates_le/"],
  founder: [
    { "@type": "Person", name: "Emmelie Kunz" },
    { "@type": "Person", name: "Tim Eder" },
  ],
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    name: "Edelpilze, Growkits & Tinkturen aus Leipzig",
    itemListElement: [
      {
        "@type": "OfferCatalog",
        name: "Frische Edelpilze",
        itemListElement: [
          {
            "@type": "Offer",
            itemOffered: {
              "@type": "Product",
              name: "Rosenseitling",
              description:
                "Rosa Austernpilze, zart und nussig, saisonal im Sommer",
            },
          },
          {
            "@type": "Offer",
            itemOffered: {
              "@type": "Product",
              name: "Pioppino",
              description: "Südlicher Schüppling, knackig und aromatisch",
            },
          },
          {
            "@type": "Offer",
            itemOffered: {
              "@type": "Product",
              name: "Lion's Mane",
              description:
                "Igelstachelbart, Vitalpilz mit besonderem Geschmack",
            },
          },
          {
            "@type": "Offer",
            itemOffered: {
              "@type": "Product",
              name: "White Pearl",
              description: "Weißer Austernpilz, vielseitig und ertragreich",
            },
          },
        ],
      },
      {
        "@type": "OfferCatalog",
        name: "Growkits: Pilze selber züchten",
        itemListElement: [
          {
            "@type": "Offer",
            itemOffered: {
              "@type": "Product",
              name: "Growkit",
              description: "Pilzzuchtset für Zuhause, in 2-3 Wochen ernten",
            },
          },
        ],
      },
      {
        "@type": "OfferCatalog",
        name: "Pilztinkturen & Extrakte",
        itemListElement: [
          {
            "@type": "Offer",
            itemOffered: {
              "@type": "Product",
              name: "Lion's Mane Tinktur",
              description: "Handgemachter Doppelextrakt aus eigenem Anbau",
            },
          },
          {
            "@type": "Offer",
            itemOffered: {
              "@type": "Product",
              name: "Reishi + Cordyceps Tinktur",
              description: "Adaptogener Doppelextrakt, immunsystemstärkend",
            },
          },
        ],
      },
    ],
  },
};

// Breadcrumb structured data
const pathSegments = Astro.url.pathname.split("/").filter(Boolean);
const breadcrumbItems = [
  {
    "@type": "ListItem",
    position: 1,
    name: "Startseite",
    item: "https://shroom-mates.de/",
  },
];
const breadcrumbNames: Record<string, string> = {
  "unsere-pilze": "Unsere Pilze",
  growkits: "Growkits",
  tinkturen: "Tinkturen",
  kontakt: "Kontakt",
  "ueber-uns": "Über uns",
  impressum: "Impressum",
  faq: "Häufige Fragen",
  gastronomie: "Gastronomie",
};
pathSegments.forEach((segment, index) => {
  breadcrumbItems.push({
    "@type": "ListItem",
    position: index + 2,
    name: breadcrumbNames[segment] || segment,
    item: `https://shroom-mates.de/${pathSegments.slice(0, index + 1).join("/")}/`,
  });
});
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbItems,
};
---

<!doctype html>
<html lang="de" class={noBackground ? "no-background" : ""}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <ClientRouter />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta
      name="google-site-verification"
      content="4MHVB3PHlJNORM3zCWb3yyka7m2Y-cEwrXlLAZitKFs"
    />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO and Open Graph -->
    <title>{title}</title>
    <link rel="canonical" href={canonicalURL} />

    <!-- Structured Data for Local Business SEO -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify(structuredData)}
    />

    <!-- Breadcrumb Structured Data -->
    {
      pathSegments.length > 0 && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(breadcrumbSchema)}
        />
      )
    }

    <!-- Location/Geo Targeting -->
    <meta name="geo.region" content="DE-SN" />
    <meta name="geo.placename" content="Leipzig" />
    <meta name="geo.position" content="51.325545403892036;12.330445796958628" />
    <meta name="ICBM" content="51.325545403892036, 12.330445796958628" />

    <!-- Keywords for local search -->
    <meta
      name="keywords"
      content="Pilze Leipzig, Edelpilze Leipzig, frische Pilze kaufen Leipzig, Pilze Gastronomie Leipzig, Pilzlieferant Leipzig, Austernpilze Leipzig, Vitalpilze Leipzig, Growkits Leipzig, Growkits kaufen, Pilze selber züchten, Pilzzuchtset, Pilztinkturen Leipzig, Pilzextrakte Leipzig, Lion's Mane Leipzig, Lion's Mane Tinktur, Reishi Tinktur, Pilzzucht Leipzig, Plagwitzer Markthalle, regionale Pilze Sachsen"
    />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="shroom-mates" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:image" content={defaultOgImage} />
    <meta property="og:image:width" content="512" />
    <meta property="og:image:height" content="512" />
    <meta
      property="og:image:alt"
      content="shroom-mates Logo - Edelpilze aus Leipzig"
    />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={defaultOgImage} />
    <meta
      name="twitter:image:alt"
      content="shroom-mates Logo - Edelpilze aus Leipzig"
    />

    <!-- Additional meta tags -->
    {
      noindex ? (
        <meta name="robots" content="noindex, nofollow" />
      ) : (
        <meta
          name="robots"
          content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
        />
      )
    }
    <meta name="author" content="shroom-mates - Emmelie Kunz & Tim Eder" />
    <meta name="theme-color" content="#fdfcea" />

    <!-- Language alternates (for future expansion) -->
    <link rel="alternate" hreflang="de" href={canonicalURL} />
    <link rel="alternate" hreflang="x-default" href={canonicalURL} />

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body>
    <!-- Skip link for keyboard navigation -->
    <a href="#main-content" class="skip-link">Zum Hauptinhalt springen</a>

    <div class="site-wrapper">
      <Header />
      <main
        id="main-content"
        class={isLandingPage ? "site-main" : "site-main with-nav-spacing"}
        aria-label="Seiteninhalt"
      >
        <slot />
      </main>

      <Footer />

      <script>
        import "../scripts/hamburger.ts";
      </script>

      <script>
        // Set scrollbar width CSS variable for full-bleed layouts
        function setScrollbarWidth() {
          const width =
            window.innerWidth - document.documentElement.clientWidth;
          document.documentElement.style.setProperty(
            "--scrollbar-width",
            `${width}px`,
          );
        }
        setScrollbarWidth();
        window.addEventListener("resize", setScrollbarWidth);
      </script>

      <script>
        // Sync --navbar-height / --navbar-height-mobile to the real header offsetHeight
        // so that content never sits behind or gaps below the fixed header.
        // Uses ResizeObserver so it fires after layout (including CSS transitions).
        function syncNavbarHeight() {
          const header = document.querySelector("header");
          if (!header) return;
          const h = `${header.offsetHeight}px`;
          document.documentElement.style.setProperty("--navbar-height", h);
          document.documentElement.style.setProperty(
            "--navbar-height-mobile",
            h,
          );
        }

        function observeHeader() {
          const header = document.querySelector("header");
          if (!header) return;
          syncNavbarHeight();
          const ro = new ResizeObserver(syncNavbarHeight);
          ro.observe(header);
        }

        observeHeader();
        document.addEventListener("astro:after-swap", observeHeader);
      </script>

      <script>
        // Fallback transitions for browsers without View Transitions API
        const hasViewTransitions = document.startViewTransition !== undefined;
        if (!hasViewTransitions) {
          document.addEventListener("astro:before-preparation", () => {
            const main = document.querySelector(".site-main");
            if (main) {
              main.classList.add("astro-transitioning");
            }
          });

          document.addEventListener("astro:after-swap", () => {
            const main = document.querySelector(".site-main");
            if (main) {
              // Small delay to ensure smooth transition
              setTimeout(() => {
                main.classList.remove("astro-transitioning");
              }, 50);
            }
          });
        }
      </script>

      <style is:global>
        @import url("../styles/global.css");

        :root {
          --duration: 0.2s;
          --scrollbar-width: 0px;
        }

        /* Detect scrollbar width for full-bleed layouts */
        @supports (scrollbar-gutter: stable) {
          :root {
            --scrollbar-width: 0px;
          }
        }

        /* Plain white background (no checkered pattern) */
        html.no-background,
        html.no-background body {
          background: #ffffff;
          background-image: none;
        }

        /* Accessibility utilities */
        .skip-link {
          position: absolute;
          top: -40px;
          left: 6px;
          background: var(--text-color);
          color: var(--bg-color);
          padding: 8px;
          text-decoration: none;
          z-index: 1001;
          border-radius: 4px;
        }

        .skip-link:focus {
          top: 6px;
        }

        .sr-only {
          position: absolute;
          width: 1px;
          height: 1px;
          padding: 0;
          margin: -1px;
          overflow: hidden;
          clip: rect(0, 0, 0, 0);
          white-space: nowrap;
          border: 0;
        }

        /* Focus styles */
        :focus-visible {
          outline: 2px solid var(--focus-color);
          outline-offset: 2px;
        }

        /* Fallback transitions for browsers without View Transitions API */
        @media (prefers-reduced-motion: no-preference) {
          .site-main {
            transition: opacity 0.2s ease-in-out;
          }

          .site-main.astro-transitioning {
            opacity: 0.8;
          }
        }

        html {
          height: 100%;
          margin: 0;
          padding: 0;
          scroll-behavior: smooth;
          overflow-x: hidden;
        }

        body {
          min-height: 100%;
          margin: 0;
          padding: 0;
          overflow-x: hidden;
        }

        * {
          box-sizing: border-box;
        }

        .site-wrapper {
          display: flex;
          flex-direction: column;
          min-height: 100vh;
          position: relative;
        }

        .site-main {
          flex: 1 0 auto;
          width: 100%;
          padding: 1rem;
        }

        .site-main:not(.with-nav-spacing) {
          max-width: none;
          padding: 0;
          margin: 0;
        }

        .site-main.with-nav-spacing {
          max-width: 1200px;
          margin: 0 auto;
          margin-top: var(--navbar-height);
          padding-top: 1.5rem;
        }

        @media (max-width: 768px) {
          .site-main.with-nav-spacing {
            margin-top: var(--navbar-height-mobile);
            padding-top: 1rem;
          }
        }

        /* Improve image loading */
        img {
          height: auto;
          max-width: 100%;
        }
      </style>
    </div>
  </body>
</html>
