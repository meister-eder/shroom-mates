# ── Test Caddyfile (self-signed TLS on any domain) ───────────
# Caddy generates self-signed certs automatically with "tls internal"

https://:443 {
	tls internal

	handle {
		root * /srv/website
		file_server
		try_files {path} {path}.html {path}/index.html
	}
}

https://:4443 {
	tls internal
	reverse_proxy storefront:4321
}

https://:9443 {
	tls internal
	reverse_proxy medusa:9000
}
