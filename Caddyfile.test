# ── Test Caddyfile (no TLS, IP-based) ────────────────────────
# Replace 159.195.31.11 with your actual server IP

:80 {
	# Root: static website
	root * /srv/website
	file_server

	@assets path /assets/* /_astro/*
	header @assets Cache-Control "public, max-age=31536000, immutable"

	try_files {path} {path}.html {path}/index.html
}

:4321 {
	# Storefront (Astro SSR)
	reverse_proxy storefront:4321
}

:9000 {
	# Medusa backend + admin
	reverse_proxy medusa:9000
}
