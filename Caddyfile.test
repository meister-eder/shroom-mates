# ── Test Caddyfile (auto TLS via sslip.io) ───────────────────
# sslip.io resolves *.IP.sslip.io → IP. Caddy gets real LE certs.
# Replace 159.195.31.11 with your server IP.

shroom-mates.159.195.31.11.sslip.io {
	root * /srv/website
	file_server
	try_files {path} {path}.html {path}/index.html
}

shop.159.195.31.11.sslip.io {
	reverse_proxy storefront:4321
}

api.159.195.31.11.sslip.io {
	reverse_proxy medusa:9000
}
